{
  "name": "baby-keys",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "A safe, colorful screen for babies to smash keys and enjoy emoji animations, sounds, and colors",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "oxlint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@fontsource/fredoka-one": "^5.2.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "oxlint": "^1.69.0",
    "prettier": "^3.5.3",
    "typescript": "~6.0.2",
    "vite": "^8.1.0"
  },
  "license": "MIT"
}
